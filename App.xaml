<Application x:Class="SimpleBlueCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0F4C81"/>
        <SolidColorBrush x:Key="SecondaryBlue" Color="#1D70B8"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EAF4FF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4DA3FF"/>
        <SolidColorBrush x:Key="BackgroundBlue" Color="#F4F9FF"/>
        <SolidColorBrush x:Key="TextDark" Color="#16324F"/>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BackgroundBlue}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="CalcButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource SecondaryBlue}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
