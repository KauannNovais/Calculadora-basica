<Window x:Class="SimpleBlueCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Blue Calculator" Height="620" Width="400" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="20" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Calculadora Simples" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                <TextBlock x:Name="OperationText" Text="" FontSize="18" Margin="0,18,0,6" HorizontalAlignment="Right" Foreground="Gray"/>
                <TextBlock x:Name="DisplayText" Text="0" FontSize="40" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource TextDark}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource LightBlue}" CornerRadius="16" Padding="14" Margin="0,0,0,16">
            <TextBlock Text="Operações básicas: soma, subtração, multiplicação e divisão" 
                       TextWrapping="Wrap" Foreground="{StaticResource PrimaryBlue}" FontWeight="SemiBold"/>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="C" Style="{StaticResource CalcButtonStyle}" Background="#D9534F" Click="Clear_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="⌫" Style="{StaticResource CalcButtonStyle}" Background="#5A8BB0" Click="Backspace_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="%" Style="{StaticResource CalcButtonStyle}" Background="#5A8BB0" Click="Percent_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="÷" Style="{StaticResource CalcButtonStyle}" Background="#0F4C81" Click="Operator_Click"/>

            <Button Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="×" Style="{StaticResource CalcButtonStyle}" Background="#0F4C81" Click="Operator_Click"/>

            <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Style="{StaticResource CalcButtonStyle}" Background="#0F4C81" Click="Operator_Click"/>

            <Button Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Style="{StaticResource CalcButtonStyle}" Background="#0F4C81" Click="Operator_Click"/>

            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Style="{StaticResource CalcButtonStyle}" Click="Number_Click"/>
            <Button Grid.Row="4" Grid.Column="2" Content="," Style="{StaticResource CalcButtonStyle}" Click="Decimal_Click"/>
            <Button Grid.Row="4" Grid.Column="3" Content="=" Style="{StaticResource CalcButtonStyle}" Background="#1AA179" Click="Equals_Click"/>
        </Grid>
    </Grid>
</Window>
